<% layout("layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <h1 class="col-6 offset-3" >Signup on Wanderlust</h1>
        <div class="col-6 offset-3">
          
            <form method="POST" action="/signup" class="needs-validation" novalidate>
                
                <div class="mb-3">
                    <label class="form-label" for="username">Username</label>
                    <input required id="username" type="text" name="username" class="form-control" >
                    <div class="valid-feedback">
                        Looks good! 
                    </div>
                    <div class="invalid-feedback">
                        Enter Valid Username! 
                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label" for="email">Email</label>
                    <input required id="email" name="email" type="email" class="form-control" >
                    
                    <div class="invalid-feedback">
                        Enter Valid Email! 
                    </div>

                </div>

                <div class="mb-3">
                    <label class="form-label" for="password">Password</label>
                    <input required id="password" name="password" type="password" class="form-control" >
                  
                </div>

                <button class="btn btn-success">Signup</button>

            </form>


        </div>
        
    </div>
</body>        