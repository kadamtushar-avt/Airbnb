<% layout("layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-8 offset-2">
            <br><br>
            <h3>Create a New Listing</h3>
    
            <form method="POST" action="/listings" novalidate  class="needs-validation" enctype="multipart/form-data" >
                <div class="mb-3">
                    <label class="form-label" for="title">Title</label>
                    <input required name="listing[title]" class="form-control" placeholder="Add a catchy title" type="text">
                    <div class="invalid-feedback">
                        Enter valid Title
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="description">Description</label>
                    <textarea required name="listing[description]" class="form-control"  type="text"></textarea>
                    <div class="invalid-feedback">
                        Enter valid Description
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="image">Upload Image</label>
                    <input  name="listing[image]" class="form-control" placeholder="Enter image link" type="file">

                </div>
                
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label class="form-label" for="price">Price</label>
                        <input required name="listing[price]"  class="form-control" placeholder="1200" >
                        <div class="invalid-feedback">
                            Please enter valid price
                        </div>
                        
                    </div>

                    <div class="mb-3 col-md-8">
                        <label class="form-label" for="country">Country</label>
                        <input required name="listing[country]" class="form-control" placeholder="India" type="text">
                        <div class="invalid-feedback">
                            Enter valid Country name
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="location">Location</label>
                    <input required name="listing[location]" class="form-control" placeholder="Jaipur,Rajastan" type="text">
                    <div class="invalid-feedback">
                        Enter a valid location
                    </div>
                </div>
                
                
                <button class="btn btn-dark mb-3 add-btn">Add</button>

            </form>
            <br><br>

        </div>
    </div>
    
</body>
